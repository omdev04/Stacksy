dist/
dist-ssr/
build/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor & OS
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/settings.json
.idea/

# TypeScript cache
*.tsbuildinfo

# Vite cache
.vite/

